# GreenWatt Lead Scoring — Environment Variables
# Copy this to .env and fill in real values
#
# Currently active: Solar vertical
# Coming soon: Roofing, Windows & Doors

# ═══════════════════════════════════════════
# API KEYS (required for lead enrichment)
# ═══════════════════════════════════════════

# Trestle Real Contact API — phone validation, contact grade, activity score, line type, name matching
# Sign up: https://trestleiq.com
TRESTLE_API_KEY=PLACEHOLDER_API_KEY

# BatchData Property API — property type, owner name, solar permit, equity, free & clear
# Sign up: https://batchdata.com
BATCHDATA_API_KEY=PLACEHOLDER_API_KEY

# TrustedForm Insights API — form input method, bot detection, owner verification, lead age
# Sign up: https://trustedform.com
TRUSTEDFORM_API_KEY=PLACEHOLDER_API_KEY

# Anthropic Claude Sonnet — LLM lead scoring (~$0.003/lead)
# Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY=PLACEHOLDER_API_KEY

# ═══════════════════════════════════════════
# AWS CONFIGURATION
# ═══════════════════════════════════════════

# AWS Region
AWS_REGION=us-east-1

# DynamoDB Table Names (must match SAM template in infrastructure/template.yaml)
DYNAMO_CONFIG_TABLE=greenwatt_vertical_configs
DYNAMO_SCORE_LOG_TABLE=greenwatt_score_log
DYNAMO_BUYER_TABLE=greenwatt_buyers

# ═══════════════════════════════════════════
# PERFORMANCE TUNING
# ═══════════════════════════════════════════

# Config Cache TTL (seconds) — how long to cache DynamoDB config before refreshing
CONFIG_CACHE_TTL=300

# API Timeout (milliseconds) — max time to wait for each enrichment API
API_TIMEOUT_MS=3000
